# Tolerate peer-dependency drift during install. The @astrojs/* family
# sometimes lags behind major Astro releases by a week or two; without
# this, Vercel's fresh `npm install` on each push fails on resolution
# even when our locked versions are compatible.
#
# Doesn't affect what gets installed — package-lock.json still pins
# exact versions. Only changes what npm does when it sees a peer-dep
# range mismatch (warn vs error).
legacy-peer-deps=true

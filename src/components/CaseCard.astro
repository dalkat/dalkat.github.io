---
/**
 * Strategy case-study tile. White card with a tint-colored disc in the
 * top-right corner. Number (italic Fraunces) + kicker, title, summary,
 * dashed-top outcome row, tag chips.
 */
import { C, fontDisplay, fontUI } from '@/lib/mesh';
import type { CaseStudy } from '@/data/strategy';

interface Props {
  c: CaseStudy;
  /** Accent color hex (rotates across the grid). */
  tint: string;
}

const { c, tint } = Astro.props;
---
<article
  style={{
    position: 'relative',
    background: C.white,
    borderRadius: '22px',
    padding: '26px 28px',
    border: `1px solid ${C.ink}10`,
    boxShadow: `0 20px 36px -24px ${C.ink}44`,
    overflow: 'hidden',
  }}
>
  {/* Corner tinted disc removed – same AI-tell as the offering blob.
      The italic Fraunces case number + kicker carry plenty of color. */}
  <div style={{ position: 'relative' }}>
    <div
      style={{
        display: 'inline-flex',
        alignItems: 'baseline',
        gap: '8px',
        fontFamily: fontUI,
        fontSize: '11px',
        letterSpacing: '0.18em',
        textTransform: 'uppercase',
        // Kicker text is inkSoft so it sits quietly under the title.
        // The italic numeral inside this block has its own `color: tint`
        // override, so the number stays vivid.
        color: C.inkSoft,
        fontWeight: 700,
        marginBottom: '12px',
      }}
    >
      <span
        style={{
          fontFamily: fontDisplay,
          fontStyle: 'italic',
          fontSize: '28px',
          color: tint,
          letterSpacing: '-0.02em',
          fontWeight: 400,
        }}
      >{c.n}</span>
      <span>{c.kicker}</span>
    </div>
    <h3
      style={{
        margin: '0 0 12px',
        fontFamily: fontDisplay,
        fontWeight: 400,
        fontSize: '26px',
        lineHeight: '1.2',
        color: C.ink,
        letterSpacing: '-0.02em',
        textWrap: 'balance',
      }}
    >{c.title}</h3>
    <p
      style={{
        margin: 0,
        fontFamily: fontUI,
        fontSize: '14px',
        lineHeight: '1.55',
        color: C.inkSoft,
        textWrap: 'pretty',
      }}
    >{c.summary}</p>
    <div
      style={{
        marginTop: '18px',
        paddingTop: '14px',
        borderTop: `1px dashed ${C.ink}22`,
        display: 'grid',
        gridTemplateColumns: '1fr auto',
        gap: '12px',
        alignItems: 'baseline',
      }}
    >
      <div
        style={{
          fontFamily: fontDisplay,
          fontStyle: 'italic',
          fontSize: '14px',
          color: tint,
        }}
      >↳ {c.outcome}</div>
      <div
        style={{
          fontFamily: fontUI,
          fontSize: '11px',
          letterSpacing: '0.1em',
          color: C.inkSoft,
          fontWeight: 600,
        }}
      >{c.year}</div>
    </div>
    {/* Tag chips intentionally hidden – kept in the data model in case
        we want to reintroduce filtering or search later. */}
  </div>
</article>

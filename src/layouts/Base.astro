---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /**
   * Open Graph image path. If omitted, defaults to the per-page generated
   * mesh card at `/og/<derived-slug>.png` (built by
   * `src/pages/og/[...slug].png.ts`). Pages that don't have a card fall
   * through to the portrait.
   */
  ogImage?: string;
  /** Either "website" (default) or "article" for individual Field Notes. */
  ogType?: 'website' | 'article';
}

const {
  title = 'Dalia Katan',
  description = 'What might life look like if designed around curiosity?',
  ogImage,
  ogType = 'website',
} = Astro.props;

const siteOrigin = (Astro.site?.origin ?? 'https://daliakatan.com').replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;

// Derive the OG slug from the current path. Mirrors the endpoint:
//   /                       → home
//   /about                  → about
//   /field-notes            → field-notes
//   /field-notes/<slug>     → field-notes/<slug>
// Pages with no generated card fall back to the portrait.
const KNOWN_TOP_LEVEL = new Set(['about', 'strategy', 'speaker', 'field-notes', 'side-quests', 'do-now']);
function ogSlugFromPath(pathname: string): string | null {
  const trimmed = pathname.replace(/^\/+|\/+$/g, '');
  if (trimmed === '') return 'home';
  if (KNOWN_TOP_LEVEL.has(trimmed)) return trimmed;
  if (trimmed.startsWith('field-notes/')) return trimmed;
  return null;
}
const derivedOgPath = (() => {
  const slug = ogSlugFromPath(Astro.url.pathname);
  return slug ? `/og/${slug}.png` : '/img/Dalia-portrait-1.jpeg';
})();
const resolvedOgImage = ogImage ?? derivedOgPath;
const ogImageUrl = resolvedOgImage.startsWith('http')
  ? resolvedOgImage
  : `${siteOrigin}${resolvedOgImage}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />

    {/* Favicon — DK gradient disc, matches the brand mark in the nav */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <meta name="theme-color" content="#fbf7ee" />

    {/* Open Graph (Facebook, LinkedIn, Slack, iMessage, etc.) */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Dalia Katan" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300..900;1,300..900&family=Inter:wght@300..700&family=Space+Grotesk:wght@300..700&family=Newsreader:wght@300..700&family=DM+Mono:wght@400;500&family=Caveat:wght@400..700&family=Instrument+Serif&display=swap"
    />
  </head>
  <body class="mesh-root">
    <slot />
  </body>
</html>

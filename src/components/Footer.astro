---
/**
 * Minimal footer: a single centered copyright line on a mesh-tinted band.
 * Earlier revisions had a DK gradient mark + name on the left; per user
 * direction these are removed in favor of a quieter, copyright-only footer.
 */
import { C, fontUI, meshBg } from '@/lib/mesh';

interface Props {
  tint?: string;
}

const { tint = C.coral } = Astro.props;
const year = new Date().getFullYear();
---
<div
  class="mesh-footer-divider"
  style={{
    height: '1px',
    background: `linear-gradient(90deg, transparent, ${C.ink}20, transparent)`,
  }}
></div>
<footer
  class="mesh-footer"
  style={{
    background: meshBg({
      base: C.paper,
      blobs: [
        [`${tint}22`, 12, 50, 55],
        [`${C.lavender}33`, 88, 50, 55],
      ],
    }),
    color: C.ink,
    padding: '32px 64px 30px',
    fontFamily: fontUI,
    textAlign: 'center',
  }}
>
  <div
    style={{
      fontFamily: fontUI,
      fontSize: '12px',
      color: C.inkSoft,
      fontWeight: 500,
      letterSpacing: '0.02em',
    }}
  >© {year} Dalia Katan. All rights reserved.</div>
</footer>

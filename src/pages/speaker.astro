---
/**
 * /speaker — Talks & Publications.
 *
 * Layout per .design-ref/design_handoff_speaker_page (variation N):
 *   1. Hero (peach mesh)            — H1 + lead paragraph.
 *   2. Section 01 · About the work  — Newsreader lead, italic venues
 *                                     summary, ↳ short-form hand-off
 *                                     to /notes.
 *   3. Section 02 · Themes          — three theme blocks (startup
 *                                     journey, product & business,
 *                                     culture-building). Each block
 *                                     is a tinted H3 + 2px tinted
 *                                     rule + white card of rows
 *                                     [year · title+where · kind chip].
 *   4. Section 03 · Invite me       — "Drop a line" + ContactForm.
 *   5. Footer (plum tint).
 *
 * Mobile behavior: the global mobile shim (src/styles/global.css)
 * collapses multi-column grids; the local <style is:global> block at
 * the bottom of this file adds the speaker-specific row collapse
 * (year + title on one line, kind chip wraps under).
 */
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Footer from '@/components/Footer.astro';
import ContactForm from '@/components/ContactForm.tsx';
import { SPEAKER_THEMES, chipInkFor } from '@/data/speaker';
import { C, fontDisplay, fontReader, fontUI, meshBg, gradientText } from '@/lib/mesh';

const gt = gradientText();

/** Sort items year-desc; "2025–6" sorts as 2025. */
function sortItems<T extends { year: number | string }>(items: T[]): T[] {
  return [...items].sort((a, b) => {
    const ay = parseInt(String(a.year).match(/\d{4}/)?.[0] ?? '0', 10);
    const by = parseInt(String(b.year).match(/\d{4}/)?.[0] ?? '0', 10);
    return by - ay;
  });
}
---
<Base
  title="Talks & Publications — Dalia Katan"
  description="Guest lectures at Princeton, conference talks, podcasts, and long-form writing for MIT Press, Deloitte Insights, and more — organized into three points of view."
>
  <PageNav current="speaker" />

  {/* ───────── Hero ───────── */}
  <section
    id="speaker"
    style={{
      background: meshBg({
        base: C.peach,
        blobs: [
          [C.lavender, 12, 22, 55],
          [C.butter,   82,  8, 45],
          [C.sky,      88, 70, 50],
          [C.mint,     18, 88, 50],
        ],
      }),
      padding: '88px 64px 64px',
      position: 'relative',
      overflow: 'hidden',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto', position: 'relative' }}>
      {/* Kicker pill hidden for now — see TODO.md ("/speaker · talks, lectures, publications") */}
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '96px',
          lineHeight: '0.98',
          letterSpacing: '-0.04em',
          color: C.ink,
          margin: 0,
          textWrap: 'balance',
          maxWidth: '1000px',
        }}
      >
        Talks &amp; Publications<span style={{ color: C.coral }}>.</span>
      </h1>
      <p
        style={{
          fontFamily: fontUI,
          fontSize: '20px',
          lineHeight: '1.5',
          color: C.ink,
          marginTop: '24px',
          maxWidth: '680px',
          textWrap: 'pretty',
        }}
      >
        I've guest lectured at Princeton, spoken on conference stages and
        podcasts, published with MIT Press and Deloitte Insights, and built
        the conferences and speaker series. A selection is below.
      </p>
    </div>
  </section>

  {/* ───────── 01 · About the work ───────── */}
  <section
    id="about-the-work"
    style={{
      background: C.paper,
      padding: '72px 64px 24px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      {/* Just the chip — no H2 title, per design (the body paragraph
          carries the orientation). */}
      <div
        style={{
          display: 'inline-flex',
          alignItems: 'center',
          gap: '10px',
          padding: '6px 14px',
          background: C.white,
          borderRadius: '999px',
          fontFamily: fontUI,
          fontSize: '12px',
          fontWeight: 700,
          letterSpacing: '0.12em',
          textTransform: 'uppercase',
          color: C.plum,
          boxShadow: `0 8px 18px -12px ${C.ink}33`,
          marginBottom: '28px',
        }}
      >
        About the work
      </div>

      <p
        style={{
          margin: '0',
          fontFamily: fontReader,
          fontSize: '24px',
          lineHeight: '1.45',
          color: C.ink,
          textWrap: 'pretty',
          letterSpacing: '-0.005em',
          maxWidth: '880px',
        }}
      >
        I speak and write about what it actually takes to build products and
        companies with care — how ideas become <em>revenue-generating
        businesses</em>, how the startup journey feels from the inside, and
        why the best products are designed more like good architecture than
        good software.
      </p>

      <p
        style={{
          margin: '24px 0 0',
          fontFamily: fontReader,
          fontStyle: 'italic',
          fontSize: '18px',
          lineHeight: '1.6',
          color: C.inkSoft,
          textWrap: 'pretty',
          maxWidth: '880px',
        }}
      >
        My talks and lectures have lived at Princeton, Stripe, Women Design
        Talks, and on a handful of podcasts I'm fond of, and my long-form
        writing has been published by MIT Press, Deloitte Insights,
        Princeton University, and more.
      </p>

      <div
        style={{
          marginTop: '20px',
          fontFamily: fontDisplay,
          fontStyle: 'italic',
          fontSize: '17px',
          color: C.inkSoft,
          textWrap: 'pretty',
        }}
      >
        ↳ for my short-form writing and blogs, visit my{' '}
        <a
          href="/notes"
          style={{
            color: C.ink,
            textDecoration: 'none',
            borderBottom: `1px solid ${C.coral}`,
            paddingBottom: '1px',
          }}
        >field notes →</a>
      </div>
    </div>
  </section>

  {/* ───────── 02 · Themes ───────── */}
  <section
    id="themes"
    style={{
      background: C.paper,
      padding: '40px 64px 80px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      <div
        style={{
          display: 'inline-flex',
          alignItems: 'center',
          gap: '10px',
          padding: '6px 14px',
          background: C.white,
          borderRadius: '999px',
          fontFamily: fontUI,
          fontSize: '12px',
          fontWeight: 700,
          letterSpacing: '0.12em',
          textTransform: 'uppercase',
          color: C.coral,
          boxShadow: `0 8px 18px -12px ${C.ink}33`,
          marginBottom: '40px',
        }}
      >
        Themes
      </div>

      <div style={{ display: 'flex', flexDirection: 'column', gap: '64px' }}>
        {SPEAKER_THEMES.map((theme) => (
          <section>
            <h3
              class="mesh-speaker-theme-h3"
              style={{
                fontFamily: fontDisplay,
                fontWeight: 400,
                fontSize: '44px',
                margin: '0 0 14px',
                letterSpacing: '-0.03em',
                color: C.ink,
                lineHeight: '1.04',
                textWrap: 'balance',
                maxWidth: '880px',
                display: 'flex',
                alignItems: 'baseline',
                gap: '18px',
              }}
            >
              <span
                style={{
                  width: '10px',
                  height: '10px',
                  borderRadius: '50%',
                  background: theme.tint,
                  display: 'inline-block',
                  alignSelf: 'center',
                  flexShrink: 0,
                }}
              ></span>
              {theme.title}
            </h3>
            <div style={{ borderBottom: `2px solid ${theme.tint}` }}></div>
            <div
              style={{
                background: C.white,
                borderRadius: '18px',
                border: `1px solid ${C.ink}10`,
                boxShadow: `0 14px 28px -22px ${C.ink}44`,
                marginTop: '14px',
              }}
            >
              {sortItems(theme.items).map((item, i) => (
                <div
                  class="mesh-speaker-row"
                  style={{
                    display: 'grid',
                    gridTemplateColumns: '70px 1fr auto',
                    gap: '24px',
                    alignItems: 'baseline',
                    padding: '16px 24px',
                    borderTop: i > 0 ? `1px dashed ${C.ink}15` : 'none',
                  }}
                >
                  <div
                    style={{
                      fontFamily: '"DM Mono", monospace',
                      fontSize: '12px',
                      color: C.inkSoft,
                      fontWeight: 500,
                      letterSpacing: '0.04em',
                      textAlign: 'left',
                    }}
                  >{item.year}</div>
                  <div>
                    <div
                      style={{
                        fontFamily: fontDisplay,
                        fontWeight: 400,
                        fontSize: '19px',
                        color: C.ink,
                        letterSpacing: '-0.01em',
                        lineHeight: '1.3',
                        textWrap: 'balance',
                      }}
                    >{item.title}</div>
                    <div
                      style={{
                        fontFamily: fontReader,
                        fontSize: '14px',
                        color: C.inkSoft,
                        marginTop: '4px',
                        fontStyle: 'italic',
                      }}
                    >{item.role} · {item.where}</div>
                  </div>
                  <span
                    class="mesh-speaker-row-chip"
                    style={{
                      justifySelf: 'end',
                      padding: '4px 10px',
                      background: `${theme.tint}2a`,
                      color: chipInkFor(theme.tint),
                      borderRadius: '6px',
                      fontFamily: fontUI,
                      fontSize: '10px',
                      fontWeight: 700,
                      letterSpacing: '0.14em',
                      textTransform: 'uppercase',
                      lineHeight: '1.25',
                      whiteSpace: 'nowrap',
                    }}
                  >{item.kind}</span>
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  {/* ───────── 03 · Invite me — Drop a line ───────── */}
  <section
    id="contact"
    style={{
      background: C.paper,
      padding: '72px 64px 96px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      <SectionHeader sub="Invite me" title="Get in touch" accent={C.coral} />
      <p
        style={{
          margin: '-18px 0 28px',
          fontFamily: fontReader,
          fontStyle: 'italic',
          fontSize: '18px',
          lineHeight: '1.55',
          color: C.inkSoft,
          maxWidth: '720px',
          textWrap: 'pretty',
        }}
      >
        If you're putting together a stage, a syllabus, or a session for your
        founders, I'm happy to shape a talk to the room.
      </p>
      {/* Two-column layout — speaker photo on the left, contact form
          on the right. The photo differentiates this contact block
          from the home + strategy ones, so the page doesn't reuse
          the same anonymous slab three times. */}
      <div
        class="mesh-speaker-contact-grid"
        style={{
          display: 'grid',
          gridTemplateColumns: '380px 1fr',
          gap: '48px',
          alignItems: 'flex-start',
        }}
      >
        <figure
          style={{
            margin: 0,
            borderRadius: '22px',
            overflow: 'hidden',
            boxShadow: `0 24px 48px -28px ${C.ink}66`,
            border: `1px solid ${C.ink}10`,
          }}
        >
          <img
            src="/img/speaking5.jpg"
            alt="Dalia speaking at the front of a room with the audience raising their hands"
            style={{
              display: 'block',
              width: '100%',
              height: 'auto',
              objectFit: 'cover',
            }}
            loading="lazy"
          />
        </figure>
        <ContactForm client:visible accent={C.coral} />
      </div>
    </div>
  </section>

  <Footer tint={C.plum} />
</Base>

<style is:global>
  /* Speaker-specific mobile collapse: the global mesh shim doesn't have
   * a 70px grid template, so the row would collapse to a single column.
   * Below 720px, drop the year column to 52px and reflow the kind chip
   * onto a new row under the title.
   *
   * Note: viewport-based fallback (not container queries) for consistency
   * with the rest of the mobile shim in global.css.
   */
  @media (max-width: 720px) {
    .mesh-root .mesh-speaker-row {
      grid-template-columns: 52px 1fr !important;
      gap: 6px 14px !important;
      padding: 14px 18px !important;
    }
    .mesh-root .mesh-speaker-row-chip {
      grid-column: 2 !important;
      justify-self: start !important;
      margin-top: 4px !important;
    }
    .mesh-root .mesh-speaker-theme-h3 {
      gap: 12px !important;
      align-items: center !important;
      font-size: 24px !important;
    }
    /* Stack the speaker contact photo + form into one column on mobile. */
    .mesh-root .mesh-speaker-contact-grid {
      grid-template-columns: 1fr !important;
      gap: 28px !important;
    }
  }
</style>

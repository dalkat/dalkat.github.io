---
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import Footer from '@/components/Footer.astro';
import SpeakingTimeline from '@/components/SpeakingTimeline.tsx';
import ContactForm from '@/components/ContactForm.tsx';
import { TOPICS, TALKS, PUBLICATIONS } from '@/data/speaker';
import { C, fontDisplay, fontReader, fontUI, meshBg, gradientText } from '@/lib/mesh';

const gt = gradientText();
const book = PUBLICATIONS.find((p) => p.featured)!;
const rest = PUBLICATIONS.filter((p) => !p.featured);
const uniCount = TALKS.filter((t) => t.topics.includes('uni')).length;
---
<Base
  title="Speaker — Dalia Katan"
  description="Talks, lectures, podcasts, and publications — guest-lecturing at Princeton, conferences and workshops on product, growth, culture, and how to build organizations that hold across difference."
>
  <PageNav current="speaker" />

  {/* ───────── Hero ───────── */}
  <section
    id="speaker"
    style={{
      background: meshBg({
        base: C.peach,
        blobs: [
          [C.lavender, 12, 22, 55],
          [C.butter,   82,  8, 45],
          [C.sky,      88, 70, 50],
          [C.mint,     18, 88, 50],
        ],
      }),
      padding: '88px 64px 96px',
      position: 'relative',
      overflow: 'hidden',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto', position: 'relative' }}>
      {/* Kicker pill hidden for now — see TODO.md ("/speaker · talks, lectures, publications") */}
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '96px',
          lineHeight: '0.97',
          letterSpacing: '-0.04em',
          color: C.ink,
          margin: 0,
          textWrap: 'balance',
          maxWidth: '1000px',
        }}
      >
        I speak about <span style={gt}>building things</span> with care.
      </h1>
      <p
        style={{
          fontFamily: fontReader,
          fontSize: '22px',
          lineHeight: '1.5',
          color: C.ink,
          marginTop: '28px',
          maxWidth: '760px',
          textWrap: 'pretty',
        }}
      >
        How ideas become revenue-generating businesses, what it actually takes
        to navigate the startup journey, and — drawing on an earlier chapter
        in international affairs — how to build cultures and workplaces that
        hold across difference.
      </p>
      <p
        style={{
          fontFamily: fontUI,
          fontSize: '16px',
          lineHeight: '1.55',
          color: C.inkSoft,
          marginTop: '18px',
          maxWidth: '760px',
          textWrap: 'pretty',
        }}
      >
        I've shared these perspectives as a guest lecturer at Princeton,
        on conference panels, in workshops, and across podcasts and live
        conversations. A selection follows.
      </p>
      <div style={{ display: 'flex', gap: '12px', marginTop: '32px', flexWrap: 'wrap' }}>
        <a
          href="#book"
          style={{
            padding: '14px 24px',
            background: C.ink,
            color: C.paper,
            borderRadius: '999px',
            fontSize: '15px',
            fontWeight: 600,
            fontFamily: fontUI,
            textDecoration: 'none',
            boxShadow: `0 14px 28px -14px ${C.ink}88`,
          }}
        >Invite me to your campus →</a>
        <a
          href="#publications"
          style={{
            padding: '14px 24px',
            background: C.white,
            color: C.ink,
            borderRadius: '999px',
            fontSize: '15px',
            fontWeight: 600,
            fontFamily: fontUI,
            textDecoration: 'none',
            boxShadow: `0 12px 22px -16px ${C.ink}55`,
          }}
        >Read my publications ↓</a>
      </div>
    </div>
  </section>

  {/* ───────── Credibility strip ───────── */}
  <section
    id="featured"
    style={{
      background: C.paper,
      padding: '64px 64px 32px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1180px', margin: '0 auto' }}>
      <div
        style={{
          fontFamily: fontUI,
          fontSize: '11px',
          letterSpacing: '0.2em',
          textTransform: 'uppercase',
          color: C.inkSoft,
          fontWeight: 700,
          marginBottom: '18px',
        }}
      >The short answer</div>
      <div style={{ display: 'grid', gridTemplateColumns: '1.2fr 1fr', gap: '18px' }}>
        {/* Book card */}
        <article
          style={{
            position: 'relative',
            background: C.white,
            borderRadius: '24px',
            padding: '32px 36px',
            border: `1px solid ${C.ink}10`,
            boxShadow: `0 24px 50px -28px ${C.ink}55`,
            overflow: 'hidden',
          }}
        >
          <div aria-hidden style={{ position: 'absolute', right: '-60px', top: '-60px', width: '240px', height: '240px', borderRadius: '50%', background: C.plum, opacity: 0.16 }}></div>
          <div aria-hidden style={{ position: 'absolute', right: '40px', bottom: '-80px', width: '160px', height: '160px', borderRadius: '50%', background: C.peach, opacity: 0.45 }}></div>
          <div style={{ position: 'relative' }}>
            <div
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '8px',
                fontFamily: fontUI,
                fontSize: '11px',
                letterSpacing: '0.18em',
                textTransform: 'uppercase',
                color: C.plum,
                fontWeight: 700,
                marginBottom: '14px',
              }}
            >
              <span style={{ width: '6px', height: '6px', borderRadius: '50%', background: C.plum }}></span>
              Published author · Book
            </div>
            <h3
              style={{
                margin: '0 0 14px',
                fontFamily: fontDisplay,
                fontWeight: 400,
                fontSize: '32px',
                lineHeight: '1.15',
                color: C.ink,
                letterSpacing: '-0.02em',
                textWrap: 'balance',
                maxWidth: '520px',
              }}
            >{book.title}</h3>
            <div
              style={{
                fontFamily: fontDisplay,
                fontStyle: 'italic',
                fontSize: '18px',
                color: C.plum,
              }}
            >↳ {book.where}, {book.year}</div>
            <p
              style={{
                margin: '14px 0 0',
                fontFamily: fontReader,
                fontSize: '15px',
                lineHeight: '1.55',
                color: C.inkSoft,
                maxWidth: '520px',
                textWrap: 'pretty',
              }}
            >
              Senior thesis turned monograph on workforce integration as a
              vehicle for inter-group reconciliation. The earliest seed of
              the practice — how do you build organizations that hold
              across difference?
            </p>
          </div>
        </article>

        {/* University lectures card */}
        <article
          style={{
            position: 'relative',
            background: C.white,
            borderRadius: '24px',
            padding: '32px 36px',
            border: `1px solid ${C.ink}10`,
            boxShadow: `0 24px 50px -28px ${C.ink}55`,
            overflow: 'hidden',
          }}
        >
          <div aria-hidden style={{ position: 'absolute', right: '-50px', top: '-50px', width: '200px', height: '200px', borderRadius: '50%', background: C.teal, opacity: 0.18 }}></div>
          <div style={{ position: 'relative' }}>
            <div
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '8px',
                fontFamily: fontUI,
                fontSize: '11px',
                letterSpacing: '0.18em',
                textTransform: 'uppercase',
                color: C.teal,
                fontWeight: 700,
                marginBottom: '14px',
              }}
            >
              <span style={{ width: '6px', height: '6px', borderRadius: '50%', background: C.teal }}></span>
              Currently open · University guest lectures
            </div>
            <div
              style={{
                fontFamily: fontDisplay,
                fontWeight: 400,
                fontSize: '64px',
                lineHeight: '1',
                letterSpacing: '-0.04em',
                color: C.ink,
                marginBottom: '8px',
              }}
            >{uniCount}</div>
            <div
              style={{
                fontFamily: fontReader,
                fontSize: '18px',
                lineHeight: '1.5',
                color: C.ink,
                textWrap: 'pretty',
                maxWidth: '360px',
              }}
            >
              Guest appearances at <em>Princeton University</em> across product, design, entrepreneurship, and inclusion — since 2015.
            </div>
            <a
              href="#book"
              style={{
                display: 'inline-flex',
                alignItems: 'center',
                gap: '6px',
                marginTop: '18px',
                fontFamily: fontUI,
                fontSize: '13px',
                fontWeight: 600,
                color: C.teal,
                textDecoration: 'none',
                borderBottom: `1.5px solid ${C.teal}`,
                paddingBottom: '2px',
              }}
            >Invite me to your seminar →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  {/* ───────── Speaking timeline ───────── */}
  <section
    id="talks"
    style={{
      background: meshBg({
        base: C.paper,
        blobs: [
          [`${C.peach}cc`,    90, 10, 35],
          [`${C.lavender}cc`,  8, 50, 35],
          [`${C.mint}cc`,     85, 92, 35],
        ],
      }),
      padding: '72px 64px 88px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1180px', margin: '0 auto' }}>
      <SectionHeader n={2} sub="Speaking" accent={C.coral}>
        Stages, classrooms, and <span style={gt}>microphones</span>.
      </SectionHeader>
      <SpeakingTimeline client:visible topics={TOPICS} talks={TALKS} />
    </div>
  </section>

  {/* ───────── Publications ───────── */}
  <section
    id="publications"
    style={{
      background: meshBg({
        base: C.butter,
        blobs: [
          [`${C.peach}cc`,    15, 25, 50],
          [`${C.lavender}cc`, 85, 20, 50],
          [`${C.mint}cc`,     50, 90, 40],
        ],
      }),
      padding: '88px 64px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1180px', margin: '0 auto' }}>
      <SectionHeader n={3} sub="Publications" accent={C.plum}>
        Words I've <span style={gt}>put my name on</span>.
      </SectionHeader>

      {/* Featured book card */}
      <article
        style={{
          marginTop: '28px',
          position: 'relative',
          background: C.white,
          borderRadius: '24px',
          padding: '36px 44px',
          border: `1px solid ${C.ink}10`,
          boxShadow: `0 28px 60px -30px ${C.ink}66`,
          overflow: 'hidden',
          display: 'grid',
          gridTemplateColumns: '1fr 220px',
          gap: '36px',
          alignItems: 'center',
        }}
      >
        <div>
          <div
            style={{
              fontFamily: fontUI,
              fontSize: '11px',
              letterSpacing: '0.2em',
              textTransform: 'uppercase',
              color: book.tint,
              fontWeight: 700,
              marginBottom: '12px',
            }}
          >Featured · Book</div>
          <h3
            style={{
              margin: '0 0 14px',
              fontFamily: fontDisplay,
              fontWeight: 400,
              fontSize: '36px',
              lineHeight: '1.12',
              color: C.ink,
              letterSpacing: '-0.02em',
              textWrap: 'balance',
            }}
          >{book.title}</h3>
          <div
            style={{
              fontFamily: fontDisplay,
              fontStyle: 'italic',
              fontSize: '18px',
              color: book.tint,
            }}
          >{book.where} · {book.year}</div>
        </div>
        {/* Spine-style book stand-in */}
        <div
          style={{
            position: 'relative',
            aspectRatio: '3 / 4',
            borderRadius: '10px',
            background: `linear-gradient(125deg, ${C.plum}, ${C.coral} 60%, ${C.peach})`,
            boxShadow: `0 22px 44px -22px ${C.ink}88, inset 0 0 0 1px ${C.ink}22`,
            display: 'flex',
            alignItems: 'flex-end',
            padding: '16px',
            color: C.paper,
            fontFamily: fontDisplay,
            fontStyle: 'italic',
            fontSize: '18px',
            lineHeight: '1.15',
            letterSpacing: '-0.01em',
            transform: 'rotate(-3deg)',
          }}
        >
          <div
            style={{
              position: 'absolute',
              left: '8px',
              top: '0',
              bottom: '0',
              width: '5px',
              background: `${C.ink}33`,
              borderRadius: '0 2px 2px 0',
            }}
          ></div>
          <div>D. Katan</div>
        </div>
      </article>

      {/* Remaining publications list */}
      <div
        style={{
          marginTop: '22px',
          background: C.white,
          borderRadius: '24px',
          padding: '8px 0',
          border: `1px solid ${C.ink}10`,
          boxShadow: `0 24px 50px -32px ${C.ink}55`,
        }}
      >
        {rest.map((p, i) => (
          <div
            style={{
              display: 'grid',
              gridTemplateColumns: '210px 1fr 110px 70px',
              gap: '28px',
              alignItems: 'baseline',
              padding: '20px 32px',
              borderTop: i === 0 ? 'none' : `1px dashed ${C.ink}1a`,
            }}
          >
            <div
              style={{
                fontFamily: fontDisplay,
                fontStyle: 'italic',
                fontWeight: 400,
                fontSize: '20px',
                color: p.tint,
                letterSpacing: '-0.01em',
              }}
            >{p.where}</div>
            <div
              style={{
                fontFamily: fontReader,
                fontSize: '17px',
                lineHeight: '1.4',
                color: C.ink,
                textWrap: 'pretty',
              }}
            >{p.title}</div>
            <div
              style={{
                fontFamily: fontUI,
                fontSize: '11px',
                letterSpacing: '0.14em',
                textTransform: 'uppercase',
                color: C.inkSoft,
                fontWeight: 700,
              }}
            >{p.kind}</div>
            <div
              style={{
                fontFamily: fontUI,
                fontSize: '13px',
                color: C.inkSoft,
                fontWeight: 600,
                textAlign: 'right',
              }}
            >{p.year}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ───────── Book me / contact ───────── */}
  <section
    id="book"
    style={{
      background: meshBg({
        base: C.paper,
        blobs: [
          [`${C.peach}cc`,     8, 80, 50],
          [`${C.lavender}cc`, 92, 20, 50],
          [`${C.mint}cc`,     50, 50, 35],
        ],
      }),
      padding: '88px 64px 100px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      <SectionHeader n={4} sub="Get in touch" accent={C.coral}>
        Invite me to your <span style={gt}>classroom or stage</span>.
      </SectionHeader>
      <p
        style={{
          margin: '12px 0 24px',
          fontFamily: fontReader,
          fontSize: '18px',
          lineHeight: '1.55',
          color: C.inkSoft,
          maxWidth: '640px',
          textWrap: 'pretty',
        }}
      >
        I take a small number of speaking engagements each year, with a
        soft preference for working sessions and seminar-style classes over
        500-person stages. Tell me what the room is, and I'll tell you if
        I'm the right person for it.
      </p>
      <ContactForm client:visible accent={C.coral} />
    </div>
  </section>

  <Footer tint={C.coral} />
</Base>

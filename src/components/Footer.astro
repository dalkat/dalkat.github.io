---
/**
 * Site footer. Mesh-tinted paper band with a brand row left + copyright right.
 * Sat below every page; a thin gradient line marks the seam with content.
 */
import { C, fontDisplay, fontUI, meshBg } from '@/lib/mesh';

interface Props {
  tint?: string;
}

const { tint = C.coral } = Astro.props;
const year = new Date().getFullYear();
---
<div
  class="mesh-footer-divider"
  style={{
    height: '1px',
    background: `linear-gradient(90deg, transparent, ${C.ink}20, transparent)`,
  }}
></div>
<footer
  class="mesh-footer"
  style={{
    background: meshBg({
      base: C.paper,
      blobs: [
        [`${tint}22`, 12, 50, 55],
        [`${C.lavender}33`, 88, 50, 55],
      ],
    }),
    color: C.ink,
    padding: '32px 64px 30px',
    fontFamily: fontUI,
  }}
>
  <div
    class="mesh-footer-row"
    style={{
      maxWidth: '1180px',
      margin: '0 auto',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'space-between',
      gap: '24px',
      flexWrap: 'wrap',
    }}
  >
    <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
      <span
        style={{
          width: '32px',
          height: '32px',
          borderRadius: '50%',
          background: `linear-gradient(135deg, ${C.coral}, ${C.plum} 60%, ${C.teal})`,
          color: C.white,
          display: 'inline-flex',
          alignItems: 'center',
          justifyContent: 'center',
          fontFamily: fontUI,
          fontSize: '12px',
          fontWeight: 700,
          boxShadow: `0 4px 10px -4px ${C.coral}66`,
        }}
      >DK</span>
      <div>
        <div
          style={{
            fontFamily: fontDisplay,
            fontWeight: 500,
            fontSize: '17px',
            letterSpacing: '-0.01em',
            color: C.ink,
            lineHeight: '1.1',
          }}
        >Dalia Katan</div>
        <div
          style={{
            fontFamily: fontUI,
            fontSize: '11px',
            color: C.inkSoft,
            letterSpacing: '0.04em',
            marginTop: '2px',
          }}
        >Brooklyn, NY</div>
      </div>
    </div>
    <div
      style={{
        fontFamily: fontUI,
        fontSize: '12px',
        color: C.inkSoft,
        fontWeight: 500,
        letterSpacing: '0.02em',
      }}
    >© {year} Dalia Katan. All rights reserved.</div>
  </div>
</footer>

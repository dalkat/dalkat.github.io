---
/**
 * Per-Field-Note dynamic route. Picks a template based on the entry's
 * `type` field (recipe → RecipeLayout, report → ReportLayout, otherwise
 * → ArticleLayout). The markdown body is rendered into the chosen layout.
 *
 * URL = /notes/<slug>/ – `slug` is usually the entry's `id`, except for:
 *   do-now-generator → SKIPPED (it lives at /quests/do-now, not here)
 *   trail-mix-method → URL slug overridden to 'trailmix' (shorter,
 *                      friendlier; still appears in the archive)
 */
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import RecipeLayout from '@/layouts/RecipeLayout.astro';
import ReportLayout from '@/layouts/ReportLayout.astro';
import { tintForType, C } from '@/lib/mesh';
import TmmCallout from '@/components/TmmCallout.tsx';

export async function getStaticPaths() {
  // Astro processes getStaticPaths in isolation (module-level locals aren't
  // always in scope), so the maps are inlined here.
  const SKIP_IDS = new Set(['do-now-generator']);
  const SLUG_OVERRIDES: Record<string, string> = {
    'trail-mix-method': 'trailmix',
  };
  const entries = await getCollection('for-you', ({ data }) => !data.draft);
  return entries
    .filter((entry) => !SKIP_IDS.has(entry.id))
    .map((entry) => {
      const slug = SLUG_OVERRIDES[entry.id] ?? entry.id;
      // Pass the URL slug through to the layout so breadcrumbs reflect
      // the actual URL (e.g. 'trailmix') rather than the file id (e.g.
      // 'trail-mix-method').
      return {
        params: { slug },
        props: { entry, slug },
      };
    });
}

const TYPE_LABELS: Record<string, string> = {
  essay: 'Essay',
  'field-guide': 'Field guide',
  framework: 'Framework',
  report: 'Report',
  tool: 'Tool',
  recipe: 'Recipe',
  letter: 'Letter',
  notes: 'Notes',
  travelogue: 'Travelogue',
  video: 'Video',
};
const THEME_LABELS: Record<string, string> = {
  'entrepreneurship-product': 'Entrepreneurship & Product',
  'workplace-teambuilding': 'Teambuilding',
  productivity: 'Productivity',
  'personal-essays': 'Personal Essays',
  food: 'Taste of Home',
};

const { entry, slug } = Astro.props;
const { Content } = await render(entry);

const typeLabel = TYPE_LABELS[entry.data.type] ?? entry.data.type;
const themeLabel = THEME_LABELS[entry.data.theme] ?? entry.data.theme;
const tint = tintForType(entry.data.type);

// ── Recipe-template configuration is held inline here per slug for now.
// Each new recipe adds an entry; ingredients/steps live alongside.
const RECIPE_CONFIG: Record<string, {
  displayWord: string;
  tagline: string;
  stats: { lbl: string; val: string }[];
  ingredients: { qty: string; name: string; note?: string }[];
  steps: { n: string; title: string; body: string; note?: string }[];
  ingredientsNote?: string;
}> = {
  'challah-recipe': {
    displayWord: 'Challah',
    tagline: 'a friday ritual, in six steps –',
    stats: [
      { lbl: 'Yields',     val: 'Two challah loaves' },
      { lbl: 'Active',     val: '1 hour' },
      { lbl: 'Total',      val: '~4 hours' },
      { lbl: 'Difficulty', val: 'forgiving' },
    ],
    ingredients: [
      { qty: '1 packet',    name: 'active dry yeast',     note: '2 ¼ tsp' },
      { qty: '1 cup',       name: 'lukewarm water' },
      { qty: '¼ cup',       name: 'sugar' },
      { qty: '⅓ cup',       name: 'vegetable oil' },
      { qty: '1',           name: 'whole egg',            note: 'optional: 2–3 eggs for a richer dough' },
      { qty: '1',           name: 'egg yolk',             note: 'for the egg wash' },
      { qty: '1 ½ tsp',     name: 'salt' },
      { qty: '4 cups',      name: 'all-purpose flour',    note: 'plus an extra ½ cup as needed' },
      { qty: 'optional',    name: 'chocolate chips or raisins', note: '~1 cup' },
      { qty: 'optional',    name: 'sesame or poppy seeds, sprinkles' },
    ],
    steps: [
      { n: 'I',   title: 'Wake the yeast.',                 body: 'Combine the yeast, sugar, and lukewarm water in a large mixing bowl. Stir and let it stand for 5–10 minutes – it should foam up. If it doesn\'t, the water was too hot or the yeast is past its prime.', note: '10 min' },
      { n: 'II',  title: 'Bring the dough together.',       body: 'Beat the egg(s) in a small cup, then add to the yeast mixture along with the oil and salt. Mix well with a wooden spoon. Gradually add 3 cups of flour, a ½ cup at a time, mixing thoroughly after each addition (clumps are fine for now – you\'ll knead them out).', note: '8 min' },
      { n: 'III', title: 'Knead like you mean it.',         body: 'As the dough thickens past spoon-and-bowl, switch to your hands and add another ½ to 1 cup of flour a ¼ cup at a time, until the dough stops being wet and sticky. Knead on a lightly floured counter for 10–15 minutes, adding flour 2 tablespoons at a time as needed, until smooth and soft. (Every batch is different – total flour usually lands between 3 ½ and 4 ½ cups; the dough shouldn\'t feel dense.) Optional: fold in chocolate chips or raisins.', note: '15 min' },
      { n: 'IV',  title: 'First rise.',                     body: 'Shape the dough into a ball and place it in a clean, lightly floured bowl. Cover with a slightly damp kitchen towel and let it rise in a warm room for 1–2 hours, until it doubles in size. Punch it down to release the air, re-dampen the towel, and let it rise again for another hour. Don\'t knead between rises.', note: '~3 hr' },
      { n: 'V',   title: 'Braid.',                          body: 'Divide the dough into equal pieces – four for a four-braid challah, or split in half first for two smaller loaves. (You can also do three or six strands.) Roll each into a rope of equal width on a lightly floured surface and braid. For a six-braid: pinch the tops together, then braid – six over one, two over six, one over five, three over one – repeat until you run out of dough.', note: '15 min' },
      { n: 'VI',  title: 'Second rise, wash, bake.',        body: 'Transfer the braid to a parchment-lined, lightly floured tray. Let it rest in a warm spot for ~30 minutes, loosely covered. Preheat the oven to 350°F. Brush with egg wash (egg yolk + a teaspoon of water). Optionally sprinkle with sesame, poppy, or sprinkles. Bake for 20–30 minutes, until golden brown – give it at least 3 inches of room on either side to grow.', note: '~60 min' },
    ],
    ingredientsNote: "p.s. – you can start the dough on Thursday evening and leave it in the fridge overnight to have it ready to bake and fully proofed for Shabbat dinner.",
  },
  'baguette-recipe': {
    displayWord: 'Baguette',
    tagline: 'crust on the outside, cloud within –',
    stats: [
      { lbl: 'Yields',     val: 'Two loaves' },
      { lbl: 'Active',     val: '30 min' },
      { lbl: 'Total',      val: '~24 hours' },
      { lbl: 'Difficulty', val: 'patient' },
    ],
    ingredients: [
      { qty: '500 g',       name: 'bread flour',       note: 'high-protein if you have it' },
      { qty: '10 g',        name: 'fine sea salt',     note: 'about 2 tsp' },
      { qty: '2 g',         name: 'instant yeast',     note: '½ tsp; less is more' },
      { qty: '375 ml',      name: 'cold water',        note: '~75% hydration' },
      { qty: 'a small bowl',name: 'flour for shaping', note: 'a couche helps' },
    ],
    steps: [
      { n: 'I',   title: 'Mix and rest.',          body: 'Combine flour, salt, yeast, and cold water in a large bowl. Mix until no dry spots remain. Cover and rest 30 minutes. The dough will look rough – this is fine.', note: '30 min' },
      { n: 'II',  title: 'Fold (four times).',    body: 'Every 30 minutes, stretch one side of the dough up and fold it over the rest. Rotate the bowl. Repeat four times in total. This builds gluten without kneading.', note: '2 hr' },
      { n: 'III', title: 'Cold ferment overnight.', body: 'Cover and refrigerate 18–24 hours. The slow rise develops flavor. Don\'t skip this.', note: '~24 hr' },
      { n: 'IV',  title: 'Divide and pre-shape.', body: 'Tip onto a floured counter. Divide in two. Gently form each piece into a loose cylinder. Rest 20 minutes seam-side down, covered.', note: '20 min' },
      { n: 'V',   title: 'Final shape and proof.',body: 'Roll each cylinder into a 14-inch baguette. Place seam-side up in a floured couche or between folds of a tea towel. Proof at room temp until puffy, ~45 minutes.', note: '45 min' },
      { n: 'VI',  title: 'Slash and bake hot.',   body: 'Preheat oven and a baking stone to 475°F. Transfer loaves seam-side down to parchment. Slash three diagonal cuts per loaf. Bake with steam (a tray of water on the bottom rack) for 22–24 minutes until deep golden.', note: '24 min' },
    ],
  },
};

const recipeCfg = RECIPE_CONFIG[entry.id];
---
{entry.data.type === 'recipe' && recipeCfg ? (
  <RecipeLayout
    title={entry.data.title}
    displayWord={recipeCfg.displayWord}
    tagline={recipeCfg.tagline}
    blurb={entry.data.blurb}
    themeLabel={themeLabel}
    slug={slug}
    year={entry.data.year}
    source={entry.data.source}
    stats={recipeCfg.stats}
    ingredients={recipeCfg.ingredients}
    steps={recipeCfg.steps}
    ingredientsNote={recipeCfg.ingredientsNote}
  />
) : entry.data.type === 'report' ? (
  <ReportLayout
    title={entry.data.title}
    blurb={entry.data.blurb}
    themeLabel={themeLabel}
    source={entry.data.source}
    year={entry.data.year}
    read_time={entry.data.read_time ?? null}
    slug={slug}
    externalUrl={entry.data.external_url}
    byline={entry.data.byline}
    tint={tint}
  >
    <Content />
  </ReportLayout>
) : (
  <ArticleLayout
    title={entry.data.title}
    blurb={entry.data.blurb}
    type={typeLabel}
    themeLabel={themeLabel}
    source={entry.data.source}
    year={entry.data.year}
    read_time={entry.data.read_time ?? null}
    slug={slug}
    tint={tint}
    highlightReel={entry.data.highlight_reel}
    highlightReelTitle={entry.data.highlight_reel ? 'Highlight reel' : undefined}
  >
    <Content />
    {/* Trail Mix Method article gets a name+email callout at the end
        for the worksheet PDF – same pattern the old Jekyll site used,
        Formspree-backed. PDF lives at /TMM-Worksheet-v1.pdf. */}
    {entry.id === 'trail-mix-method' && <TmmCallout client:visible tint={tint} />}
  </ArticleLayout>
)}

---
/**
 * Strategy offering card. White tile with a soft mesh blob in the corner,
 * "Practice N" tint badge, title, then a bulleted services list separated
 * by a dashed top border. (The italic kicker line has been retired – each
 * card now goes straight from title to services list.)
 */
import { C, fontDisplay, fontUI, meshBg } from '@/lib/mesh';
import type { Offering } from '@/data/strategy';

interface Props {
  offering: Offering;
  /** 1-based practice number. */
  n: number;
}

const { offering, n } = Astro.props;
const { group, tint, blob, services } = offering;
---
<article
  style={{
    position: 'relative',
    background: C.white,
    borderRadius: '22px',
    padding: '28px 28px 34px',
    border: `1px solid ${C.ink}10`,
    boxShadow: `0 18px 32px -22px ${C.ink}44`,
    overflow: 'hidden',
    display: 'flex',
    flexDirection: 'column',
  }}
>
  {/* Corner blob removed – read as decorative AI-tell. The card carries
      enough hierarchy with the Practice tint chip + dashed divider. */}
  <div style={{ position: 'relative' }}>
    <div
      style={{
        display: 'inline-block',
        padding: '3px 10px',
        borderRadius: '6px',
        background: tint,
        color: C.ink,
        fontFamily: fontUI,
        fontSize: '11px',
        fontWeight: 700,
        letterSpacing: '0.14em',
        textTransform: 'uppercase',
        marginBottom: '14px',
      }}
    >Practice {n}</div>
    <h3
      style={{
        margin: '0 0 18px',
        fontFamily: fontDisplay,
        fontWeight: 400,
        fontSize: '24px',
        lineHeight: '1.15',
        color: C.ink,
        letterSpacing: '-0.02em',
        textWrap: 'balance',
      }}
    >{group}</h3>
    <ul
      style={{
        listStyle: 'disc outside',
        margin: 0,
        padding: '16px 0 0 18px',
        display: 'grid',
        gap: '6px',
        borderTop: `1px dashed ${C.ink}22`,
      }}
    >
      {services.map((s) => (
        <li
          style={{
            fontFamily: fontUI,
            fontSize: '14px',
            color: C.ink,
            fontWeight: 500,
            paddingLeft: '4px',
          }}
        >{s}</li>
      ))}
    </ul>
  </div>
</article>

---
/**
 * /side-quests — things I built outside of paid work.
 *
 * Hero (peach-mesh + kicker pill + Fraunces flourish) over a stacked
 * single-column list of large quest cards. Each card has a mesh-tinted
 * thumb tile on the left and copy on the right; `coming-soon` cards swap
 * the outbound CTA for a pill, and tiles with an `award` field render
 * a small honor pill above the title.
 *
 * Add new entries by appending to `SIDE_QUESTS` in `src/data/side-quests.ts`.
 */
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import Footer from '@/components/Footer.astro';
import { C, fontDisplay, fontReader, fontUI, meshBg, gradientText } from '@/lib/mesh';
import { SIDE_QUESTS } from '@/data/side-quests';

const gt = gradientText();
---
<Base
  title="Side quests — Dalia Katan"
  description="Side projects, weekend tools, and small experiments — things I've built outside of paid work."
>
  <PageNav current="side-quests" />

  {/* ───────── Hero ───────── */}
  <section
    id="side-quests"
    style={{
      background: meshBg({
        base: C.peach,
        blobs: [
          [`${C.butter}cc`,   12, 18, 50],
          [`${C.lavender}cc`, 88, 12, 45],
          [`${C.mint}cc`,     72, 92, 40],
          [`${C.coral}aa`,    10, 88, 35],
        ],
      }),
      padding: '88px 64px 72px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      <div
        style={{
          display: 'inline-flex',
          gap: '10px',
          alignItems: 'center',
          padding: '6px 14px',
          background: `${C.white}cc`,
          borderRadius: '999px',
          fontFamily: fontUI,
          fontSize: '12px',
          fontWeight: 700,
          letterSpacing: '0.14em',
          textTransform: 'uppercase',
          color: C.coral,
          marginBottom: '24px',
        }}
      >
        <span style={{ width: '6px', height: '6px', borderRadius: '50%', background: C.coral }}></span>
        /side-quests · things I've made
      </div>
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '96px',
          lineHeight: '0.98',
          letterSpacing: '-0.04em',
          color: C.ink,
          margin: 0,
          textWrap: 'balance',
          maxWidth: '900px',
        }}
      >
        Side <span style={gt}>quests</span><span style={{ color: C.coral }}>.</span>
      </h1>
      <p
        style={{
          fontFamily: fontReader,
          fontStyle: 'italic',
          fontSize: '22px',
          lineHeight: '1.5',
          color: C.inkSoft,
          marginTop: '20px',
          maxWidth: '780px',
          textWrap: 'pretty',
        }}
      >
        Weekend tools, half-built experiments, and things I made because
        I wanted them to exist. Mostly free, mostly small, mostly running
        on the cheapest tier of something.
      </p>
    </div>
  </section>

  {/* ───────── Cards ───────── */}
  <section
    style={{
      background: C.paper,
      padding: '64px 64px 96px',
      scrollMarginTop: '80px',
    }}
  >
    <div
      style={{
        maxWidth: '960px',
        margin: '0 auto',
        display: 'grid',
        gap: '22px',
      }}
    >
      {SIDE_QUESTS.map((q) => {
        const isComingSoon = q.status === 'coming-soon';
        const isExternal = !!q.href && q.href.startsWith('http');
        const Tag = q.href ? 'a' : 'article';
        return (
          <Tag
            href={q.href}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
            style={{
              background: C.white,
              borderRadius: '24px',
              padding: '28px',
              border: `1px solid ${C.ink}10`,
              boxShadow: `0 18px 36px -22px ${C.ink}55`,
              display: 'grid',
              gridTemplateColumns: '180px 1fr',
              gap: '28px',
              alignItems: 'flex-start',
              textDecoration: 'none',
              color: C.ink,
              cursor: q.href ? 'pointer' : 'default',
              opacity: isComingSoon ? 0.92 : 1,
            }}
          >
            {/* Thumb — product screenshot if `image` is set, else mesh tile.
                The kind pill sits in the bottom-left corner in both cases. */}
            <div
              style={{
                width: '180px',
                height: '180px',
                borderRadius: '20px',
                background: q.image
                  ? C.paper
                  : meshBg({
                      base: q.tint,
                      blobs: [
                        [`${C.butter}dd`,   80, 24, 65],
                        [`${C.white}aa`,    18, 78, 60],
                        [`${C.lavender}aa`, 50, 50, 40],
                      ],
                    }),
                border: `1px solid ${C.ink}10`,
                position: 'relative',
                overflow: 'hidden',
              }}
            >
              {q.image ? (
                <img
                  src={q.image}
                  alt={`${q.title} screenshot`}
                  style={{
                    display: 'block',
                    width: '100%',
                    height: '100%',
                    objectFit: 'cover',
                    objectPosition: 'center 30%',
                  }}
                />
              ) : (
                <div
                  style={{
                    position: 'absolute',
                    inset: 0,
                    backgroundImage: `repeating-linear-gradient(135deg, transparent 0 11px, ${C.ink}10 11px 12px)`,
                  }}
                ></div>
              )}
              {/* Kind pill — small brand mark in the corner */}
              <div
                style={{
                  position: 'absolute',
                  bottom: '14px',
                  left: '14px',
                  padding: '6px 12px',
                  background: `${C.white}f0`,
                  borderRadius: '999px',
                  fontFamily: fontUI,
                  fontSize: '11px',
                  fontWeight: 700,
                  letterSpacing: '0.12em',
                  textTransform: 'uppercase',
                  color: C.ink,
                  boxShadow: `0 6px 14px -10px ${C.ink}66`,
                }}
              >{q.kind}</div>
            </div>

            {/* Right column */}
            <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
              {q.award && (
                <div
                  style={{
                    display: 'inline-flex',
                    alignSelf: 'flex-start',
                    alignItems: 'center',
                    gap: '8px',
                    padding: '7px 14px 7px 10px',
                    background: meshBg({
                      base: C.butter,
                      blobs: [
                        [`${C.peach}dd`,  100, 50, 80],
                        [`${C.white}bb`,    0, 50, 60],
                      ],
                    }),
                    borderRadius: '999px',
                    border: `1px solid ${C.ink}10`,
                    boxShadow: `0 6px 14px -10px ${C.ink}55`,
                    fontFamily: fontUI,
                    fontSize: '12px',
                    fontWeight: 600,
                    color: C.ink,
                    letterSpacing: '-0.005em',
                  }}
                >
                  {q.award.icon && <span style={{ fontSize: '14px', lineHeight: 1 }}>{q.award.icon}</span>}
                  <span>{q.award.text}</span>
                </div>
              )}
              <div
                style={{
                  display: 'flex',
                  alignItems: 'baseline',
                  flexWrap: 'wrap',
                  columnGap: '14px',
                  rowGap: '4px',
                }}
              >
                <div
                  style={{
                    fontFamily: fontDisplay,
                    fontWeight: 400,
                    fontSize: '42px',
                    lineHeight: '1.02',
                    letterSpacing: '-0.025em',
                    color: C.ink,
                    textWrap: 'balance',
                  }}
                >{q.title}</div>
                {q.year && (
                  <div
                    style={{
                      fontFamily: 'Caveat, cursive',
                      fontSize: '24px',
                      color: q.tint,
                      transform: 'rotate(-2deg)',
                      lineHeight: 1,
                    }}
                  >— {q.year}</div>
                )}
              </div>
              <div
                style={{
                  fontFamily: fontReader,
                  fontSize: '17px',
                  lineHeight: '1.6',
                  color: C.inkSoft,
                  textWrap: 'pretty',
                  maxWidth: '620px',
                }}
              >{q.blurb}</div>
              <div
                style={{
                  marginTop: '8px',
                  paddingTop: '14px',
                  borderTop: `1px dashed ${C.ink}18`,
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'space-between',
                  fontFamily: fontUI,
                  fontSize: '13px',
                  color: q.tint,
                  fontWeight: 600,
                  flexWrap: 'wrap',
                  gap: '12px',
                }}
              >
                {isComingSoon ? (
                  <span
                    style={{
                      padding: '6px 14px',
                      background: `${q.tint}22`,
                      color: q.tint,
                      borderRadius: '999px',
                      fontSize: '12px',
                      letterSpacing: '0.12em',
                      textTransform: 'uppercase',
                      fontWeight: 700,
                    }}
                  >Coming soon</span>
                ) : (
                  <span>{isExternal ? 'Visit' : 'Try it'} {isExternal ? '↗' : '→'}</span>
                )}
                <span style={{ color: C.inkSoft, fontWeight: 500 }}>
                  {q.href ? q.href.replace(/^https?:\/\//, '') : ''}
                </span>
              </div>
            </div>
          </Tag>
        );
      })}
    </div>
  </section>

  <Footer tint={C.coral} />
</Base>

---
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import Footer from '@/components/Footer.astro';
import DoNowCard from '@/components/DoNowCard.tsx';
import { DO_NOW_PROMPTS } from '@/data/do-now-prompts';
import { C, fontDisplay, fontReader, fontUI, meshBg, gradientText } from '@/lib/mesh';

const gt = gradientText();
---
<Base
  title="Do Now — Dalia Katan"
  description="A small oracle for the moment you're stuck. One card at a time — specific, surprising, doable before your next coffee."
>
  <PageNav current="quests" />

  {/* ───────── Hero ───────── */}
  <section
    id="donow"
    style={{
      background: meshBg({
        base: C.butter,
        blobs: [
          [C.peach,           12, 22, 55],
          [`${C.coral}cc`,    85, 14, 45],
          [`${C.lavender}cc`, 86, 84, 50],
          [`${C.mint}cc`,     14, 86, 45],
        ],
      }),
      padding: '72px 64px 36px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '920px', margin: '0 auto', textAlign: 'center' }}>
      {/* Kicker pill hidden for now — see TODO.md ("/quests/do-now · a small oracle") */}
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '100px',
          lineHeight: '0.94',
          letterSpacing: '-0.04em',
          color: C.ink,
          margin: 0,
          textWrap: 'balance',
        }}
      >
        What should you <span style={gt}>do right now</span>?
      </h1>
      <p
        style={{
          fontFamily: fontReader,
          fontStyle: 'italic',
          fontSize: '22px',
          lineHeight: '1.5',
          color: C.inkSoft,
          margin: '20px auto 0',
          maxWidth: '640px',
          textWrap: 'pretty',
        }}
      >
        A tiny generator for the moment you're stuck. One card at a time —
        specific, surprising, doable before your next coffee.
      </p>
    </div>
  </section>

  {/* ───────── Generator card ───────── */}
  <section
    style={{
      padding: '32px 0 72px',
      background: meshBg({
        base: C.paper,
        blobs: [
          [`${C.peach}aa`,    90, 14, 30],
          [`${C.lavender}aa`,  8, 78, 30],
        ],
      }),
      scrollMarginTop: '80px',
    }}
  >
    <DoNowCard client:visible prompts={DO_NOW_PROMPTS} />

    {/* Single-line "cousin of the trail mix method" hand-off, centered
        under the card. The previous "About this · Outsource the
        decision." section is hidden — see TODO.md. */}
    <p
      style={{
        maxWidth: '760px',
        margin: '28px auto 0',
        textAlign: 'center',
        fontFamily: fontReader,
        fontStyle: 'italic',
        fontSize: '15px',
        lineHeight: '1.5',
        color: C.inkSoft,
      }}
    >
      ↳ a cousin of the{' '}
      <a
        href="/notes/trailmix/"
        style={{
          color: C.coral,
          textDecoration: 'underline',
          textUnderlineOffset: '3px',
          textDecorationColor: `${C.coral}80`,
        }}
      >trail mix method</a>.
    </p>
  </section>

  <Footer tint={C.coral} />
</Base>

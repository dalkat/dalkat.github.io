---
/**
 * Generic article shell — used for letters (sabbatical-update*) and the
 * trailmix tool post. Hero w/ breadcrumbs + kicker + headline + lead, then
 * a single reader-friendly markdown body column on paper.
 *
 * Pages that need bespoke layouts (recipes, reports, do-now) use their
 * own template files; this is the default for type ∈ {letter, tool, notes,
 * essay, field-guide, travelogue}.
 */
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Kicker from '@/components/Kicker.astro';
import HighlightReel from '@/components/HighlightReel.tsx';
import type { ReelImage } from '@/components/HighlightReel.tsx';
import { C, fontDisplay, fontReader, fontUI, meshBg } from '@/lib/mesh';

interface Props {
  title: string;
  blurb: string;
  type: string;
  themeLabel: string;
  source: string;
  year: number;
  read_time: number | null;
  slug: string;
  /** Tint accent color (defaults to coral). */
  tint?: string;
  /** Optional photo gallery rendered after the article body. */
  highlightReel?: ReelImage[];
  /** Optional H2 heading shown above the highlight reel. */
  highlightReelTitle?: string;
}
const {
  title, blurb, type, themeLabel, source, year, read_time, slug,
  tint = C.coral, highlightReel, highlightReelTitle,
} = Astro.props;
const readLabel = read_time == null ? null : `${read_time} min read`;
---
<Base title={`${title} — Field Notes — Dalia Katan`} description={blurb}>
  <PageNav current="foryou" />

  {/* ───────── Hero ───────── */}
  <section
    style={{
      background: meshBg({
        base: C.paper,
        blobs: [
          [`${C.peach}cc`,    90, 14, 40],
          [`${C.lavender}cc`,  8, 50, 40],
          [`${C.mint}cc`,     85, 92, 35],
        ],
      }),
      padding: '72px 64px 56px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '800px', margin: '0 auto' }}>
      <Breadcrumbs theme={themeLabel} slug={slug} />
      <Kicker category={type} date={year} read={readLabel ?? undefined} tint={tint} />
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '68px',
          lineHeight: '1.02',
          letterSpacing: '-0.035em',
          color: C.ink,
          margin: '24px 0 0',
          textWrap: 'balance',
        }}
      >{title}</h1>
      <p
        style={{
          fontFamily: fontReader,
          fontStyle: 'italic',
          fontSize: '22px',
          lineHeight: '1.5',
          color: C.inkSoft,
          marginTop: '20px',
          maxWidth: '800px',
          textWrap: 'pretty',
        }}
      >{blurb}</p>
      <div
        style={{
          marginTop: '20px',
          fontFamily: fontUI,
          fontSize: '12px',
          letterSpacing: '0.08em',
          textTransform: 'uppercase',
          color: C.inkSoft,
          fontWeight: 600,
        }}
      >↳ Originally published on {source}</div>
    </div>
  </section>

  {/* ───────── Body ───────── */}
  <section
    style={{
      background: C.paper,
      padding: '56px 64px 96px',
      scrollMarginTop: '80px',
    }}
  >
    <article
      class="mesh-prose"
      style={{
        maxWidth: '800px',
        margin: '0 auto',
        fontFamily: fontReader,
        fontSize: '18px',
        lineHeight: '1.7',
        color: C.inkSoft,
      }}
    >
      <slot />
    </article>
  </section>

  {highlightReel && highlightReel.length > 0 && (
    <section
      style={{
        background: C.paper,
        padding: '0 64px 96px',
        scrollMarginTop: '80px',
      }}
    >
      <div style={{ maxWidth: '800px', margin: '0 auto' }}>
        {highlightReelTitle && (
          <h2
            style={{
              fontFamily: fontDisplay,
              fontWeight: 500,
              fontSize: '32px',
              letterSpacing: '-0.02em',
              color: C.ink,
              margin: '0 0 8px',
              textWrap: 'balance',
            }}
          >{highlightReelTitle}</h2>
        )}
        <HighlightReel client:visible images={highlightReel} tint={tint} />
      </div>
    </section>
  )}

  <Footer tint={tint} />
</Base>

<style is:global>
  .mesh-prose h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 32px;
    letter-spacing: -0.02em;
    color: #221a3a;
    margin: 48px 0 16px;
    text-wrap: balance;
  }
  .mesh-prose h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.02em;
    color: #221a3a;
    margin: 36px 0 12px;
    text-wrap: balance;
  }
  .mesh-prose p {
    margin: 0 0 20px;
    text-wrap: pretty;
  }
  .mesh-prose a {
    color: #ff8a7a;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .mesh-prose blockquote {
    margin: 32px 0;
    padding: 22px 28px;
    border-left: 4px solid #ff8a7a;
    background: #fff;
    border-radius: 0 14px 14px 0;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    color: #221a3a;
  }
  /* Tailwind's preflight reset wipes default list-style from ul/ol;
   * restore disc/decimal markers explicitly so blog posts render
   * bullets and numbered lists correctly. Coral marker accent for
   * a touch of the v7 palette inside long-form prose. */
  .mesh-prose ul {
    list-style: disc outside;
    margin: 0 0 24px;
    padding-left: 28px;
  }
  .mesh-prose ol {
    list-style: decimal outside;
    margin: 0 0 24px;
    padding-left: 32px;
  }
  .mesh-prose ul ul,
  .mesh-prose ol ol,
  .mesh-prose ul ol,
  .mesh-prose ol ul {
    margin: 8px 0 8px;
  }
  .mesh-prose ul ul { list-style: circle outside; }
  .mesh-prose ol ol { list-style: lower-alpha outside; }
  .mesh-prose li {
    margin-bottom: 8px;
    padding-left: 4px;
  }
  .mesh-prose li::marker {
    color: #ff8a7a;
    font-weight: 600;
  }
  .mesh-prose code {
    background: #f3edf9;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'DM Mono', monospace;
    font-size: 0.92em;
  }
  .mesh-prose hr {
    border: none;
    border-top: 1px dashed #221a3a30;
    margin: 36px 0;
  }
  /* Embedded documents (Slideshare, YouTube, etc.) inside a markdown body. */
  .mesh-prose iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    margin: 32px 0;
    border-radius: 14px;
    border: 1px solid #221a3a18;
    box-shadow: 0 24px 50px -28px #221a3a55;
    background: #fff;
  }
  /* Inline images inside a markdown body (e.g. trail-mix diagrams) — soft
   * card framing, centered in the column. Full-bleed photos override below. */
  .mesh-prose img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 32px auto;
    border-radius: 14px;
    border: 1px solid #221a3a15;
    box-shadow: 0 18px 36px -24px #221a3a55;
  }
  .mesh-prose .full-bleed img {
    margin: 0;
    border-radius: 0;
    border: none;
    box-shadow: none;
  }
  /* Full-bleed inline figure — breaks out of the 720px article column
   * to span the full viewport. Used for the photos sprinkled through
   * the sabbatical updates. */
  .mesh-prose .full-bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    margin-top: 56px;
    margin-bottom: 56px;
  }
  .mesh-prose .full-bleed img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 86vh;
    object-fit: cover;
  }
  .mesh-prose .full-bleed figcaption {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 15px;
    color: #4a3f6e;
    text-align: center;
    padding: 16px 24px 0;
    text-wrap: pretty;
  }
</style>

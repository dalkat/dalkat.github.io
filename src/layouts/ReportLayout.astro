---
/**
 * Report template — modeled on the design's MeshReportTeams (content-pages.jsx).
 * Hero (kicker + bold gradient-accent headline + byline + lead),
 * then the embedded Slideshare PDF / iframe via the markdown body slot.
 *
 * Two surfaces hidden for now (see TODO.md):
 *   1. The Breadcrumbs row above the kicker
 *   2. The "Read the report ↗ via Source" CTA row above the body
 */
import Base from '@/layouts/Base.astro';
import PageNav from '@/components/PageNav.astro';
import Footer from '@/components/Footer.astro';
import Kicker from '@/components/Kicker.astro';
import { C, fontDisplay, fontReader, fontUI, meshBg } from '@/lib/mesh';

interface Props {
  title: string;
  blurb: string;
  themeLabel: string;
  source: string;
  year: number;
  read_time: number | null;
  slug: string;
  /** Optional URL for the source PDF / slideshare. */
  externalUrl?: string;
  /** Optional byline like "Co-author · January 2018 · Via Deloitte
   *  Center for the Edge". Rendered under the H1, before the blurb. */
  byline?: string;
  /** Accent tint (defaults to teal for reports). */
  tint?: string;
}
const { title, blurb, source, year, read_time, externalUrl, byline, tint = C.teal } = Astro.props;
const readLabel = read_time == null ? '15 min read' : `${read_time} min read`;
---
<Base title={`${title} — Field Notes — Dalia Katan`} description={blurb} ogType="article">
  <PageNav current="notes" />

  {/* ───────── Hero ───────── */}
  <section
    style={{
      background: meshBg({
        base: C.mint,
        blobs: [
          [C.butter,         12, 18, 50],
          [`${C.lavender}cc`,82, 12, 45],
          [`${C.peach}cc`,   65, 88, 40],
          [C.sky,            18, 82, 40],
        ],
      }),
      padding: '72px 64px 32px',
      scrollMarginTop: '80px',
    }}
  >
    <div style={{ maxWidth: '1080px', margin: '0 auto' }}>
      {/* Breadcrumbs row hidden for now — see TODO.md.
          Previously: <Breadcrumbs theme={themeLabel} slug={slug} /> */}
      <Kicker category="Report" date={year} read={readLabel} tint={tint} />
      <h1
        style={{
          fontFamily: fontDisplay,
          fontWeight: 400,
          fontSize: '60px',
          lineHeight: '1.05',
          letterSpacing: '-0.03em',
          color: C.ink,
          margin: '24px 0 0',
          textWrap: 'balance',
          maxWidth: '920px',
        }}
      >{title}</h1>
      {byline && (
        <div
          style={{
            marginTop: '20px',
            fontFamily: fontUI,
            fontSize: '13px',
            letterSpacing: '0.08em',
            textTransform: 'uppercase',
            color: C.inkSoft,
            fontWeight: 600,
          }}
        >{byline}</div>
      )}
      <p
        style={{
          fontFamily: fontUI,
          fontSize: '20px',
          lineHeight: '1.5',
          color: C.ink,
          marginTop: byline ? '16px' : '24px',
          maxWidth: '800px',
          textWrap: 'pretty',
        }}
      >{blurb}</p>
      {/* "Read the report ↗" CTA + "via Source" hidden for now — see
          TODO.md. externalUrl + source are kept on the data side so
          they're trivial to restore when we bring the button back. */}
    </div>
  </section>

  {/* ───────── Body (embedded slideshare / markdown content) ───────── */}
  <section style={{ background: C.paper, padding: '16px 64px 80px', scrollMarginTop: '80px' }}>
    <article
      class="mesh-prose"
      style={`max-width:1080px;margin:0 auto;font-family:${fontReader};font-size:18px;line-height:1.7;color:${C.inkSoft};--post-tint:${tint};`}
    >
      <slot />
    </article>
  </section>

  <Footer tint={tint} />
</Base>
